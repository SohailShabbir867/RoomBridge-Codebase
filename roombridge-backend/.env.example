# ═══════════════════════════════════════════════════════════
# RoomBridge Backend — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────
MONGO_URI=mongodb+srv://mahar:mahar@project.e5k7hmj.mongodb.net/?appName=RoomBridge

# ── JWT Auth ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_min_32_chars_change_this
JWT_EXPIRE=7d

# ── Cloudinary (https://cloudinary.com/console) ──────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email — Gmail SMTP (use App Password) ─────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=sohailshabbir25598@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=RoomBridge <noreply@roombridge.pk>
